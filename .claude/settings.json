            "command": "if echo \"${CLAUDE_TOOL_USE_FILE_PATH}\" | grep -qE '\\.py$'; then python3.12 -m py_compile \"${CLAUDE_TOOL_USE_FILE_PATH}\" 2>&1 && echo '  ✓ syntax OK' || echo '  ✗ syntax ERROR'; fi"
          }
        ]
      }
    ]
  }
